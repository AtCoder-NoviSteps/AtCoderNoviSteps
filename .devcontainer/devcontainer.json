// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
  "name": "AtCoder NoviSteps",
  "service": "web",
  "workspaceFolder": "/usr/src/app",
  // Use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "dockerComposeFile": ["../compose.yaml"],
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],
  // Features to add to the dev container. More info: https://containers.dev/features.
  // "features": {},
  //
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [
    5173,
    5432, // for postgres
    6543 // for postgres
  ],
  // "shutdownAction": "none",
  //
  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && pnpm install",
  //
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "settings": {
        "auto-rename-tag.activationOnLanguage": [
          "html",
          "xml",
          "javascript",
          "typescript",
          "svelte"
        ],
        "css.validate": false,
        "editor.codeActionsOnSave": {
          "source.fixAll": true
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.formatOnPaste": false,
        "editor.quickSuggestions": {
          "strings": true
        },
        "eslint.validate": ["html"],
        "eslint.workingDirectories": [
          {
            "mode": "auto"
          }
        ],
        "files.associations": {
          "*.css": "tailwindcss"
        },
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[svelte]": {
          "editor.defaultFormatter": "svelte.svelte-vscode"
        },
        "[prisma]": {
          "editor.defaultFormatter": "Prisma.prisma"
        },
        "[markdown]": {
          "editor.formatOnSave": false
        },
        "svelte.enable-ts-plugin": true
      },
      "extensions": [
        "anthropic.claude-code",
        "bradlc.vscode-tailwindcss",
        "christian-kohler.path-intellisense",
        "csstools.postcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "formulahendry.auto-rename-tag",
        "ms-playwright.playwright",
        "Prisma.prisma",
        "streetsidesoftware.code-spell-checker",
        "svelte.svelte-vscode",
        "vscode-icons-team.vscode-icons"
      ]
    }
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096 --dns-result-order=ipv4first",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  }
  //
  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
